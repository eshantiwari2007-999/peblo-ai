# ──────────────────────────────────────────────────────────────
# Peblo — AI Notes Workspace — Environment Variables Example
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the required values.

# ── Database ──────────────────────────────────────────────────
# Standard PostgreSQL connection string (for standard hosting like Supabase, Railway, Neon):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct PostgreSQL URL (required if DATABASE_URL uses Prisma Postgres prisma+postgres:// format).
# Used as the runtime query URL so Next.js build works correctly.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── NextAuth ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# ── Google Gemini AI ──────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
